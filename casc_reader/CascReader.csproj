<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- ServerGC: parallel multi-heap GC, 5-10x faster on alloc-heavy workloads (reflecting 85k STU files) -->
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
    <RetainVMGarbageCollection>true</RetainVMGarbageCollection>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../deps/OWLib/TACTLib/TACTLib/TACTLib.csproj" />
    <ProjectReference Include="../deps/OWLib/TankLib/TankLib.csproj" />
  </ItemGroup>
</Project>
